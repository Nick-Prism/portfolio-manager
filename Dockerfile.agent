FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y gcc curl && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN TMPDIR=/app/tmp mkdir -p /app/tmp && pip install --no-cache-dir -r requirements.txt && rm -rf /app/tmp

COPY . .

# Default command: run the agent engine in continuous mode
CMD ["python", "main.py"]
