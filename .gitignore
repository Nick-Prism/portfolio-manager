# =============================================================================
# Zeta AI Portfolio Manager — .gitignore
# =============================================================================

# --- Secrets (NEVER commit these) ---
.env
*.pem
*.key
service-account*.json
gcp-credentials*.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.egg

# --- Testing & coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# --- Type checking ---
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/
*.out

# --- Local data / cache ---
data/cache/
*.csv
*.parquet
*.h5
*.pkl

# --- Docker ---
.docker/

# --- Node (if any tooling is added) ---
node_modules/
